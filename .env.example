# Shared secret with every consuming app.
# Generate a strong value: openssl rand -base64 48
JWT_SECRET=change-me-in-production-use-openssl-rand-base64-48

# Resend settings used to send OTP emails.
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=Interview Bank

# Redis settings for OTP storage.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
