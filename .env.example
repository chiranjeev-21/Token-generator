# Shared secret with every consuming app.
# Generate a strong value: openssl rand -base64 48
JWT_SECRET=change-me-in-production-use-openssl-rand-base64-48

# SMTP settings used to send OTP emails.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Redis settings for OTP storage.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
